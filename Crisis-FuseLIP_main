def preflight_check():
    """
    Run each (encoder, fusion) combination on 5 dummy samples.
    Catches dimension mismatches, LoRA errors, etc. before full training.
    """
    print("=" * 70)
    print("PHASE 0: PRE-FLIGHT SANITY CHECK")
    print("=" * 70)
    
    task_name = 'informativeness'
    num_classes = len(TASKS[task_name]['label_map'])
    
    all_passed = True
    
    for encoder_name in ['clip', 'blip', 'siglip']:
        print(f"\n  Testing {encoder_name.upper()}...")
        config = ENCODER_CONFIGS[encoder_name]
        
        for fusion_name in FUSION_METHODS:
            try:
                # Build model
                model = UnifiedClassifier(
                    encoder_name=encoder_name,
                    fusion_name=fusion_name,
                    num_classes=num_classes,
                    lora_rank=8,
                    lora_alpha=16,
                    lora_dropout=0.3,
                    clf_dropout=0.3,
                ).to(DEVICE)
                
                # Dummy inputs
                B = 5
                dummy_imgs = torch.randn(B, 3, 224, 224).to(DEVICE)
                dummy_ids = torch.randint(0, 1000, (B, config['max_length'])).to(DEVICE)
                dummy_mask = torch.ones(B, config['max_length']).long().to(DEVICE)
                
                # Forward pass
                with torch.no_grad():
                    with autocast():
                        if fusion_name == 'cca':
                            logits, cca_losses = model.forward_with_cca_loss(
                                dummy_imgs, dummy_ids, dummy_mask)
                        else:
                            logits = model(dummy_imgs, dummy_ids, dummy_mask)
                
                # Verify output shape
                assert logits.shape == (B, num_classes), \
                    f"Expected {(B, num_classes)}, got {logits.shape}"
                
                # Count parameters
                trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
                total = sum(p.numel() for p in model.parameters())
                
                print(f"    ✓ {fusion_name:16s}: PASSED  "
                      f"(trainable: {trainable:,} / {total:,} = {100*trainable/total:.2f}%)")
                
                del model
                cleanup()
                
            except Exception as e:
                print(f"    ✗ {fusion_name:16s}: FAILED")
                print(f"      Error: {e}")
                all_passed = False
        
        cleanup_aggressive()
    
    if not all_passed:
        print("\n" + "=" * 70)
        print("PRE-FLIGHT CHECK FAILED. Fix errors before proceeding.")
        print("=" * 70)
        sys.exit(1)
    
    print("\n" + "=" * 70)
    print("✓ All 9 configurations passed pre-flight check.")
    print("=" * 70 + "\n")


