# DATASET


class CrisisMMDDataset(Dataset):
    """Unified dataset for all encoders."""
    
    def __init__(self, task_name: str, split: str, transform, 
                 tokenizer, max_length: int, encoder_name: str):
        self.task = TASKS[task_name]
        self.transform = transform
        self.tokenizer = tokenizer
        self.max_length = max_length
        self.encoder_name = encoder_name
        self.samples = []
        
        tsv_path = os.path.join(SPLITS_DIR, f"{self.task['prefix']}_{split}.tsv")
        df = pd.read_csv(tsv_path, sep='\t', on_bad_lines='skip')
        
        for _, row in df.iterrows():
            img_rel = row.get('image', '')
            if pd.isna(img_rel) or img_rel == '':
                continue
            img_path = os.path.join(BASE_DIR, img_rel)
            if not os.path.exists(img_path):
                continue
            
            tweet = str(row.get('tweet_text', '')) if pd.notna(row.get('tweet_text')) else ''
            llava = str(row.get('LLaVA_text', '')) if pd.notna(row.get('LLaVA_text')) else ''
            text = (tweet.strip() + ' ' + llava.strip()).strip()
            if not text:
                continue
            
            label_str = str(row.get('label', '')).strip()
            if label_str not in self.task['label_map']:
                continue
            
            self.samples.append({
                'image_path': img_path,
                'text': text,
                'label': self.task['label_map'][label_str]
            })
    
    def __len__(self):
        return len(self.samples)
    
    def __getitem__(self, idx):
        s = self.samples[idx]
        
        # Load image
        try:
            img = Image.open(s['image_path']).convert('RGB')
            img = self.transform(img)
        except Exception:
            img = torch.zeros(3, 224, 224)
        
        # Tokenize text
        if self.encoder_name == 'siglip':
            enc = self.tokenizer.tokenizer(
                s['text'], padding='max_length', max_length=self.max_length,
                truncation=True, return_tensors='pt'
            )
            input_ids = enc['input_ids'].squeeze(0)
            pad_id = self.tokenizer.tokenizer.pad_token_id or 1
            attention_mask = (input_ids != pad_id).long()
        else:
            enc = self.tokenizer(
                s['text'], padding='max_length', max_length=self.max_length,
                truncation=True, return_tensors='pt'
            )
            input_ids = enc['input_ids'].squeeze(0)
            attention_mask = enc['attention_mask'].squeeze(0)
        
        return {
            'image': img,
            'input_ids': input_ids,
            'attention_mask': attention_mask,
            'label': torch.tensor(s['label'], dtype=torch.long)
        }


def get_transforms(split: str):
    """Get image transforms for training/evaluation."""
    mean = (0.48145466, 0.4578275, 0.40821073)
    std = (0.26862954, 0.26130258, 0.27577711)
    
    if split == 'train':
        return transforms.Compose([
            transforms.Resize((224, 224)),
            transforms.RandomHorizontalFlip(),
            transforms.ColorJitter(0.2, 0.2, 0.2, 0.1),
            transforms.ToTensor(),
            transforms.Normalize(mean, std),
        ])
    return transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize(mean, std),
    ])


def get_tokenizer(encoder_name: str):
    """Get tokenizer for encoder."""
    config = ENCODER_CONFIGS[encoder_name]
    if encoder_name == 'clip':
        return CLIPTokenizer.from_pretrained(config['model_name'])
    elif encoder_name == 'blip':
        return AutoTokenizer.from_pretrained(config['model_name'])
    elif encoder_name == 'siglip':
        return SiglipProcessor.from_pretrained(config['model_name'])
    else:
        raise ValueError(f"Unknown encoder: {encoder_name}")


def make_loaders(task_name: str, encoder_name: str, batch_size: int = 16):
    """Create data loaders for a task-encoder combination."""
    config = ENCODER_CONFIGS[encoder_name]
    tokenizer = get_tokenizer(encoder_name)
    
    datasets = {}
    for split in ['train', 'dev', 'test']:
        datasets[split] = CrisisMMDDataset(
            task_name, split, 
            get_transforms(split if split == 'train' else 'val'),
            tokenizer, config['max_length'], encoder_name
        )
    
    loaders = {
        'train': DataLoader(datasets['train'], batch_size=batch_size, 
                           shuffle=True, num_workers=0, pin_memory=False, drop_last=True),
        'val': DataLoader(datasets['dev'], batch_size=batch_size,
                         shuffle=False, num_workers=0, pin_memory=False),
        'test': DataLoader(datasets['test'], batch_size=batch_size,
                          shuffle=False, num_workers=0, pin_memory=False),
    }
    
    # Dynamic num_classes
    num_classes = len(TASKS[task_name]['label_map'])
    
    return loaders, datasets['train'], num_classes


# LOSS FUNCTIONS


class FocalLoss(nn.Module):
    """Focal loss for imbalanced classification (humanitarian task)."""
    
    def __init__(self, weight: Optional[torch.Tensor] = None, gamma: float = 2.0):
        super().__init__()
        self.weight = weight
        self.gamma = gamma
    
    def forward(self, inputs: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
        ce = F.cross_entropy(inputs, targets, reduction='none')
        pt = torch.exp(-ce)
        focal = ((1 - pt) ** self.gamma) * ce
        if self.weight is not None:
            w = self.weight.to(inputs.device)
            focal = w.gather(0, targets) * focal
        return focal.mean()


class WeightedCE(nn.Module):
    """Weighted cross-entropy loss."""
    
    def __init__(self, weight: Optional[torch.Tensor] = None):
        super().__init__()
        self.weight = weight
    
    def forward(self, inputs: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
        w = self.weight.to(inputs.device) if self.weight is not None else None
        return F.cross_entropy(inputs, targets, weight=w)


def compute_class_weights(train_dataset, num_classes: int) -> torch.Tensor:
    """Compute inverse-frequency class weights."""
    labels = [s['label'] for s in train_dataset.samples]
    counts = Counter(labels)
    total = len(labels)
    
    weights = torch.zeros(num_classes)
    for c in range(num_classes):
        weights[c] = total / (num_classes * counts.get(c, 1))
    weights = weights / weights.mean()
    
    return weights


def build_loss_fn(task_name: str, train_dataset, num_classes: int):
    """Build appropriate loss function for task."""
    class_weights = compute_class_weights(train_dataset, num_classes)
    
    if task_name == 'humanitarian':
        return FocalLoss(weight=class_weights, gamma=2.0)
    else:
        return WeightedCE(weight=class_weights)


# LORA 


class LoRALayer(nn.Module):
    """Low-Rank Adaptation layer."""
    
    def __init__(self, original: nn.Linear, rank: int, alpha: int, dropout: float):
        super().__init__()
        self.original = original
        self.scaling = alpha / rank
        
        # Freeze original weights
        for p in self.original.parameters():
            p.requires_grad = False
        
        # LoRA matrices
        self.lora_A = nn.Linear(original.in_features, rank, bias=False)
        self.lora_B = nn.Linear(rank, original.out_features, bias=False)
        self.dropout = nn.Dropout(dropout)
        
        # Initialization
        nn.init.kaiming_uniform_(self.lora_A.weight, a=math.sqrt(5))
        nn.init.zeros_(self.lora_B.weight)
    
    @property
    def weight(self):
        return self.original.weight
    
    @property
    def bias(self):
        return self.original.bias
    
    @property
    def in_features(self):
        return self.original.in_features
    
    @property
    def out_features(self):
        return self.original.out_features
    
    def forward(self, x: torch.Tensor) -> torch.Tensor:
        return self.original(x) + self.scaling * self.lora_B(
            self.lora_A(self.dropout(x)))
    
    def __getattr__(self, name: str):
        try:
            return super().__getattr__(name)
        except AttributeError:
            if 'original' in self.__dict__:
                return getattr(self.original, name)
            raise


def apply_lora(model: nn.Module, targets: List[str], 
               rank: int, alpha: int, dropout: float) -> Tuple[nn.Module, int]:
    """Apply LoRA to specified layers in model."""
    count = 0
    for name, module in list(model.named_modules()):
        if any(t in name for t in targets) and isinstance(module, nn.Linear):
            parts = name.split('.')
            parent = model
            for part in parts[:-1]:
                parent = getattr(parent, part)
            setattr(parent, parts[-1], LoRALayer(module, rank, alpha, dropout))
            count += 1
    return model, count

# FUSION 

class CCAFusion(nn.Module):
    """
    Canonical Correlation Analysis fusion.
    Adapts to asymmetric dimensions (e.g., CLIP: 768/512).
    """
    
    def __init__(self, vision_dim: int, text_dim: int, projection_dim: int = 512,
                 lambda_l2: float = 1e-4, mu_orth: float = 0.01, eps: float = 1e-6):
        super().__init__()
        self.projection_dim = projection_dim
        self.lambda_l2 = lambda_l2
        self.mu_orth = mu_orth
        self.eps = eps
        
        # Projection matrices (handle asymmetric dims)
        self.W_cca_v = nn.Linear(vision_dim, projection_dim, bias=False)
        self.W_cca_t = nn.Linear(text_dim, projection_dim, bias=False)
        
        # Orthogonal initialization
        nn.init.orthogonal_(self.W_cca_v.weight)
        nn.init.orthogonal_(self.W_cca_t.weight)
        
        # LayerNorm for stability
        self.norm_v = nn.LayerNorm(projection_dim)
        self.norm_t = nn.LayerNorm(projection_dim)
        
        self.output_dim = 2 * projection_dim
    
    def forward(self, vision_feat: torch.Tensor, text_feat: torch.Tensor) -> torch.Tensor:
        hv = self.norm_v(self.W_cca_v(vision_feat))
        ht = self.norm_t(self.W_cca_t(text_feat))
        return torch.cat([ht, hv], dim=-1)
    
    def compute_cca_loss(self, vision_feat: torch.Tensor, 
                         text_feat: torch.Tensor) -> Dict[str, torch.Tensor]:
        hv = self.W_cca_v(vision_feat)
        ht = self.W_cca_t(text_feat)
        
        B = hv.size(0)
        
        # Per-dimension Pearson correlation
        hv_c = hv - hv.mean(dim=0, keepdim=True)
        ht_c = ht - ht.mean(dim=0, keepdim=True)
        
        cov = (hv_c * ht_c).sum(dim=0) / (B - 1 + self.eps)
        var_v = (hv_c ** 2).sum(dim=0) / (B - 1 + self.eps)
        var_t = (ht_c ** 2).sum(dim=0) / (B - 1 + self.eps)
        
        std_v = torch.sqrt(var_v + self.eps)
        std_t = torch.sqrt(var_t + self.eps)
        
        corr_per_dim = cov / (std_v * std_t)
        mean_corr = corr_per_dim.mean()
        
        # L2 regularization
        l2_reg = (torch.norm(self.W_cca_v.weight, p='fro') ** 2 +
                  torch.norm(self.W_cca_t.weight, p='fro') ** 2)
        
        loss_cca = -mean_corr + self.lambda_l2 * l2_reg
        
        # Orthogonality constraint
        Wv = self.W_cca_v.weight
        Wt = self.W_cca_t.weight
        I = torch.eye(self.projection_dim, device=Wv.device, dtype=Wv.dtype)
        
        loss_orth = (torch.norm(Wv @ Wv.T - I, p='fro') ** 2 +
                     torch.norm(Wt @ Wt.T - I, p='fro') ** 2)
        
        loss_aux = loss_cca + self.mu_orth * loss_orth
        
        return {
            'loss_aux': loss_aux,
            'loss_cca': loss_cca.detach(),
            'loss_orth': loss_orth.detach(),
            'mean_corr': mean_corr.detach(),
        }


class GatedFusion(nn.Module):
    """
    Cross-modal gated fusion.
    Adapts to asymmetric dimensions.
    """
    
    def __init__(self, vision_dim: int, text_dim: int, 
                 hidden_dim: int = 512, dropout: float = 0.1):
        super().__init__()
        
        # Gate networks
        self.vision_gate = nn.Sequential(
            nn.Linear(vision_dim, hidden_dim),
            nn.Sigmoid()
        )
        self.text_gate = nn.Sequential(
            nn.Linear(text_dim, hidden_dim),
            nn.Sigmoid()
        )
        
        # Feature projections
        self.vision_proj = nn.Sequential(
            nn.Linear(vision_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.GELU(),
            nn.Dropout(dropout),
        )
        self.text_proj = nn.Sequential(
            nn.Linear(text_dim, hidden_dim),
            nn.LayerNorm(hidden_dim),
            nn.GELU(),
            nn.Dropout(dropout),
        )
        
        self.output_dim = 2 * hidden_dim
    
    def forward(self, vision_feat: torch.Tensor, text_feat: torch.Tensor) -> torch.Tensor:
        v_gate = self.vision_gate(vision_feat)
        t_gate = self.text_gate(text_feat)
        
        v_proj = self.vision_proj(vision_feat)
        t_proj = self.text_proj(text_feat)
        
        # Cross-gating
        v_gated = t_gate * v_proj
        t_gated = v_gate * t_proj
        
        return torch.cat([t_gated, v_gated], dim=-1)


class BidirectionalCrossAttention(nn.Module):
    """
    Bidirectional cross-attention fusion.
    Adapts to asymmetric dimensions.
    """
    
    def __init__(self, vision_dim: int, text_dim: int,
                 hidden_dim: int = 512, num_heads: int = 8, dropout: float = 0.1):
        super().__init__()
        
        # Project to common space
        self.vision_proj = nn.Linear(vision_dim, hidden_dim)
        self.text_proj = nn.Linear(text_dim, hidden_dim)
        
        # Cross-attention modules
        self.t2v_attn = nn.MultiheadAttention(
            hidden_dim, num_heads, dropout=dropout, batch_first=True)
        self.v2t_attn = nn.MultiheadAttention(
            hidden_dim, num_heads, dropout=dropout, batch_first=True)
        
        # Layer norms
        self.t2v_norm = nn.LayerNorm(hidden_dim)
        self.v2t_norm = nn.LayerNorm(hidden_dim)
        
        # Output projections (asymmetric for parameter efficiency)
        self.t2v_out = nn.Linear(hidden_dim, hidden_dim)  # 512
        self.v2t_out = nn.Linear(hidden_dim, hidden_dim - 128)  # 384
        
        # Global projections from original features
        self.vision_global = nn.Linear(vision_dim, hidden_dim - 128)  # 384
        self.text_global = nn.Linear(text_dim, hidden_dim)  # 512
        
        self.dropout = nn.Dropout(dropout)
        
        # 512 + 512 + 384 + 384 = 1792
        self.output_dim = hidden_dim + hidden_dim + (hidden_dim - 128) + (hidden_dim - 128)
    
    def forward(self, vision_feat: torch.Tensor, text_feat: torch.Tensor) -> torch.Tensor:
        # Project to common space
        v = self.vision_proj(vision_feat).unsqueeze(1)
        t = self.text_proj(text_feat).unsqueeze(1)
        
        # Text-to-vision attention
        t2v, _ = self.t2v_attn(query=t, key=v, value=v)
        t2v = self.t2v_norm(t + self.dropout(t2v))
        t2v = self.t2v_out(t2v.squeeze(1))
        
        # Vision-to-text attention
        v2t, _ = self.v2t_attn(query=v, key=t, value=t)
        v2t = self.v2t_norm(v + self.dropout(v2t))
        v2t = self.v2t_out(v2t.squeeze(1))
        
        # Global projections
        t_global = self.text_global(text_feat)
        v_global = self.vision_global(vision_feat)
        
        return torch.cat([t_global, t2v, v_global, v2t], dim=-1)


def get_fusion_module(fusion_name: str, vision_dim: int, text_dim: int, 
                      dropout: float = 0.3) -> nn.Module:
    """Factory for fusion modules."""
    if fusion_name == 'cca':
        return CCAFusion(vision_dim, text_dim, projection_dim=512)
    elif fusion_name == 'gated':
        return GatedFusion(vision_dim, text_dim, hidden_dim=512, dropout=dropout)
    elif fusion_name == 'cross_attention':
        return BidirectionalCrossAttention(
            vision_dim, text_dim, hidden_dim=512, num_heads=8, dropout=dropout)
    else:
        raise ValueError(f"Unknown fusion method: {fusion_name}")


# CLASSIFIER


class UnifiedClassifier(nn.Module):
    """
    Unified multimodal classifier supporting all encoder-fusion combinations.
    """
    
    def __init__(self, encoder_name: str, fusion_name: str, num_classes: int,
                 lora_rank: int = 16, lora_alpha: int = 32,
                 lora_dropout: float = 0.4, clf_dropout: float = 0.3):
        super().__init__()
        
        self.encoder_name = encoder_name
        self.fusion_name = fusion_name
        self.num_classes = num_classes
        
        config = ENCODER_CONFIGS[encoder_name]
        self.vision_dim = config['vision_dim']
        self.text_dim = config['text_dim']
        
        # Load backbone
        self._load_backbone(encoder_name, config['model_name'])
        
        # Freeze backbone
        for p in self.backbone.parameters():
            p.requires_grad = False
        
        # Apply LoRA
        self._apply_lora(encoder_name, config['lora_targets'],
                        lora_rank, lora_alpha, lora_dropout)
        
        # Initialize fusion
        self.fusion = get_fusion_module(
            fusion_name, self.vision_dim, self.text_dim, clf_dropout)
        
        # Classification head
        fusion_dim = self.fusion.output_dim
        self.classifier = nn.Sequential(
            nn.Linear(fusion_dim, 512),
            nn.LayerNorm(512),
            nn.GELU(),
            nn.Dropout(clf_dropout),
            nn.Linear(512, num_classes),
        )
    
    def _load_backbone(self, encoder_name: str, model_name: str):
        """Load the appropriate backbone model."""
        if encoder_name == 'clip':
            self.backbone = CLIPModel.from_pretrained(model_name)
        elif encoder_name == 'blip':
            self.backbone = BlipModel.from_pretrained(model_name)
        elif encoder_name == 'siglip':
            self.backbone = SiglipModel.from_pretrained(model_name)
        else:
            raise ValueError(f"Unknown encoder: {encoder_name}")
    
    def _apply_lora(self, encoder_name: str, targets: List[str],
                    rank: int, alpha: int, dropout: float):
        """Apply LoRA to backbone."""
        if encoder_name == 'clip':
            self.backbone.vision_model, nv = apply_lora(
                self.backbone.vision_model, targets, rank, alpha, dropout)
            self.backbone.text_model, nt = apply_lora(
                self.backbone.text_model, targets, rank, alpha, dropout)
        elif encoder_name == 'blip':
            self.backbone.vision_model, nv = apply_lora(
                self.backbone.vision_model, targets, rank, alpha, dropout)
            self.backbone.text_model, nt = apply_lora(
                self.backbone.text_model, targets, rank, alpha, dropout)
        elif encoder_name == 'siglip':
            self.backbone.vision_model, nv = apply_lora(
                self.backbone.vision_model, targets, rank, alpha, dropout)
            self.backbone.text_model, nt = apply_lora(
                self.backbone.text_model, targets, rank, alpha, dropout)
    
    def extract_features(self, images: torch.Tensor, 
                         input_ids: torch.Tensor,
                         attention_mask: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        """Extract vision and text features from backbone."""
        if self.encoder_name == 'clip':
            v_out = self.backbone.vision_model(pixel_values=images)
            t_out = self.backbone.text_model(input_ids=input_ids,
                                             attention_mask=attention_mask)
            v_feat = v_out.pooler_output
            t_feat = t_out.pooler_output
            
        elif self.encoder_name == 'blip':
            v_out = self.backbone.vision_model(pixel_values=images)
            t_out = self.backbone.text_model(input_ids=input_ids,
                                             attention_mask=attention_mask)
            v_feat = v_out.pooler_output
            t_feat = t_out.last_hidden_state[:, 0]  # CLS token
            
        elif self.encoder_name == 'siglip':
            v_out = self.backbone.vision_model(pixel_values=images)
            t_out = self.backbone.text_model(input_ids=input_ids,
                                             attention_mask=attention_mask)
            v_feat = v_out.pooler_output
            t_feat = t_out.pooler_output
            
        return v_feat, t_feat
    
    def forward(self, images: torch.Tensor, input_ids: torch.Tensor,
                attention_mask: torch.Tensor) -> torch.Tensor:
        v_feat, t_feat = self.extract_features(images, input_ids, attention_mask)
        fused = self.fusion(v_feat, t_feat)
        return self.classifier(fused)
    
    def forward_with_cca_loss(self, images: torch.Tensor, input_ids: torch.Tensor,
                               attention_mask: torch.Tensor) -> Tuple[torch.Tensor, Dict]:
        """Forward with CCA auxiliary loss (only for CCA fusion)."""
        v_feat, t_feat = self.extract_features(images, input_ids, attention_mask)
        fused = self.fusion(v_feat, t_feat)
        logits = self.classifier(fused)
        
        if self.fusion_name == 'cca':
            cca_losses = self.fusion.compute_cca_loss(v_feat, t_feat)
        else:
            cca_losses = {'loss_aux': torch.tensor(0.0, device=logits.device)}
        
        return logits, cca_losses
    
    def lora_params(self) -> List[nn.Parameter]:
        """Get LoRA parameters."""
        return [p for n, p in self.named_parameters() if 'lora_' in n]
    
    def head_params(self) -> List[nn.Parameter]:
        """Get fusion + classifier parameters."""
        return list(self.fusion.parameters()) + list(self.classifier.parameters())


# TRAINING & EVALUATION


def train_epoch(model: nn.Module, loader: DataLoader, optimizer: torch.optim.Optimizer,
                loss_fn: nn.Module, device: torch.device, scaler: GradScaler,
                fusion_name: str, cca_weight: float = 0.1, accum: int = 2) -> Dict:
    """Train for one epoch."""
    model.train()
    total_loss = 0.0
    total_cca_loss = 0.0
    all_preds, all_labels = [], []
    optimizer.zero_grad()
    
    for i, batch in enumerate(loader):
        imgs = batch['image'].to(device)
        ids = batch['input_ids'].to(device)
        mask = batch['attention_mask'].to(device)
        lbl = batch['label'].to(device)
        
        with autocast():
            if fusion_name == 'cca':
                logits, cca_losses = model.forward_with_cca_loss(imgs, ids, mask)
                loss_task = loss_fn(logits, lbl)
                loss_cca = cca_losses['loss_aux']
                loss = (loss_task + cca_weight * loss_cca) / accum
                total_cca_loss += loss_cca.item()
            else:
                logits = model(imgs, ids, mask)
                loss = loss_fn(logits, lbl) / accum
        
        scaler.scale(loss).backward()
        
        if (i + 1) % accum == 0:
            scaler.step(optimizer)
            scaler.update()
            optimizer.zero_grad()
        
        total_loss += loss.item() * accum
        preds = logits.argmax(-1).cpu().numpy()
        all_preds.extend(preds)
        all_labels.extend(lbl.cpu().numpy())
    
    p, l = np.array(all_preds), np.array(all_labels)
    return {
        'loss': total_loss / len(loader),
        'cca_loss': total_cca_loss / len(loader) if fusion_name == 'cca' else 0.0,
        'acc': accuracy_score(l, p),
        'macro_f1': f1_score(l, p, average='macro', zero_division=0),
        'weighted_f1': f1_score(l, p, average='weighted', zero_division=0),
    }


@torch.no_grad()
def evaluate(model: nn.Module, loader: DataLoader, loss_fn: nn.Module,
             device: torch.device) -> Dict:
    """Evaluate model."""
    model.eval()
    total_loss = 0.0
    all_preds, all_labels = [], []
    
    for batch in loader:
        imgs = batch['image'].to(device)
        ids = batch['input_ids'].to(device)
        mask = batch['attention_mask'].to(device)
        lbl = batch['label'].to(device)
        
        with autocast():
            logits = model(imgs, ids, mask)
            loss = loss_fn(logits, lbl)
        
        total_loss += loss.item()
        preds = logits.argmax(-1).cpu().numpy()
        all_preds.extend(preds)
        all_labels.extend(lbl.cpu().numpy())
    
    p, l = np.array(all_preds), np.array(all_labels)
    return {
        'loss': total_loss / len(loader),
        'acc': accuracy_score(l, p),
        'macro_f1': f1_score(l, p, average='macro', zero_division=0),
        'weighted_f1': f1_score(l, p, average='weighted', zero_division=0),
    }

