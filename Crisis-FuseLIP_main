def run_experiments():
    """
    Main experiment loop.
    3 tasks × 3 encoders × 3 fusions × 5 seeds × 5 HP configs = 675 training runs
    """
    
    # Initialize results storage
    all_results = []
    
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    results_file = os.path.join(RESULTS_DIR, f"results_{timestamp}.csv")
    
    total_seeds = len(SEEDS)
    total_tasks = len(TASKS)
    total_encoders = len(ENCODER_CONFIGS)
    total_fusions = len(FUSION_METHODS)
    total_hp = len(HP_CONFIGS)
    
    total_experiments = total_seeds * total_tasks * total_encoders * total_fusions
    total_runs = total_experiments * total_hp
    
    print("=" * 70)
    print("EXPERIMENT CONFIGURATION")
    print("=" * 70)
    print(f"  Seeds:          {total_seeds} ({SEEDS})")
    print(f"  Tasks:          {total_tasks} ({list(TASKS.keys())})")
    print(f"  Encoders:       {total_encoders} ({list(ENCODER_CONFIGS.keys())})")
    print(f"  Fusion Methods: {total_fusions} ({FUSION_METHODS})")
    print(f"  HP Configs:     {total_hp}")
    print(f"  Total Experiments: {total_experiments}")
    print(f"  Total Training Runs: {total_runs}")
    print("=" * 70 + "\n")
    
    experiment_idx = 0
    
    # ── MAIN LOOP ────────────────────────────────────────────────────────────
    for seed in SEEDS:
        print(f"\n{'#'*70}")
        print(f"# SEED: {seed}")
        print(f"{'#'*70}")
        
        set_seed(seed)
        
        for task_name in TASKS.keys():
            num_classes = len(TASKS[task_name]['label_map'])
            
            print(f"\n{'='*60}")
            print(f"  TASK: {task_name.upper()} ({num_classes} classes) | SEED: {seed}")
            print(f"{'='*60}")
            
            for encoder_name in ENCODER_CONFIGS.keys():
                print(f"\n  ── ENCODER: {encoder_name.upper()} ──")
                
                # Load data for this encoder
                loaders, train_ds, num_classes = make_loaders(
                    task_name, encoder_name, BATCH_SIZE)
                
                print(f"     Data: train={len(loaders['train'].dataset)}, "
                      f"val={len(loaders['val'].dataset)}, "
                      f"test={len(loaders['test'].dataset)}")
                
                # Build loss function
                loss_fn = build_loss_fn(task_name, train_ds, num_classes)
                
                for fusion_name in FUSION_METHODS:
                    experiment_idx += 1
                    
                    print(f"\n     ┌─ FUSION: {fusion_name.upper()} "
                          f"[Exp {experiment_idx}/{total_experiments}]")
                    
                    best_trial = {
                        'val_f1': -1,
                        'hp_config': None,
                        'state': None,
                        'hp_idx': -1,
                    }
                    
                    # ── HYPERPARAMETER SEARCH ────────────────────────────────
                    for hp_idx, hp_config in enumerate(HP_CONFIGS):
                        print(f"     │  Trial {hp_idx+1}/{total_hp}: "
                              f"rank={hp_config['lora_rank']}, "
                              f"α={hp_config['lora_alpha']}, "
                              f"drop={hp_config['lora_dropout']:.2f}")
                        
                        try:
                            # Build model
                            model = UnifiedClassifier(
                                encoder_name=encoder_name,
                                fusion_name=fusion_name,
                                num_classes=num_classes,
                                lora_rank=hp_config['lora_rank'],
                                lora_alpha=hp_config['lora_alpha'],
                                lora_dropout=hp_config['lora_dropout'],
                                clf_dropout=hp_config['lora_dropout'],
                            ).to(DEVICE)
                            
                            # Optimizer
                            optimizer = AdamW([
                                {'params': model.head_params(), 
                                 'lr': hp_config['head_lr']},
                                {'params': model.lora_params(), 
                                 'lr': hp_config['backbone_lr']},
                            ], weight_decay=0.01)
                            
                            scheduler = ReduceLROnPlateau(
                                optimizer, mode='max', factor=0.5, patience=1)
                            scaler = GradScaler()
                            
                            # Training loop
                            trial_best_val_f1 = -1
                            trial_best_state = None
                            no_improve = 0
                            
                            for epoch in range(EPOCHS_PER_TRIAL):
                                tr = train_epoch(
                                    model, loaders['train'], optimizer, loss_fn,
                                    DEVICE, scaler, fusion_name, CCA_WEIGHT, GRAD_ACCUM)
                                
                                va = evaluate(model, loaders['val'], loss_fn, DEVICE)
                                
                                scheduler.step(va['weighted_f1'])
                                
                                if va['weighted_f1'] > trial_best_val_f1:
                                    trial_best_val_f1 = va['weighted_f1']
                                    trial_best_state = {
                                        k: v.cpu().clone() 
                                        for k, v in model.state_dict().items()
                                    }
                                    no_improve = 0
                                else:
                                    no_improve += 1
                                    if no_improve >= PATIENCE:
                                        break
                            
                            print(f"     │    → val_f1={trial_best_val_f1:.4f} "
                                  f"(epochs: {epoch+1})")
                            
                            # Update best trial
                            if trial_best_val_f1 > best_trial['val_f1']:
                                best_trial = {
                                    'val_f1': trial_best_val_f1,
                                    'hp_config': hp_config,
                                    'state': trial_best_state,
                                    'hp_idx': hp_idx,
                                }
                            
                            del model, optimizer, scheduler, scaler
                            cleanup()
                            
                        except Exception as e:
                            print(f"     │    ✗ Trial failed: {e}")
                            cleanup()
                            continue
                    
                    # ── EVALUATE BEST TRIAL ON TEST SET ──────────────────────
                    if best_trial['state'] is not None:
                        hp = best_trial['hp_config']
                        print(f"     │")
                        print(f"     │  ★ Best: Trial {best_trial['hp_idx']+1} "
                              f"(rank={hp['lora_rank']}, val_f1={best_trial['val_f1']:.4f})")
                        
                        # Rebuild best model
                        model = UnifiedClassifier(
                            encoder_name=encoder_name,
                            fusion_name=fusion_name,
                            num_classes=num_classes,
                            lora_rank=hp['lora_rank'],
                            lora_alpha=hp['lora_alpha'],
                            lora_dropout=hp['lora_dropout'],
                            clf_dropout=hp['lora_dropout'],
                        ).to(DEVICE)
                        
                        model.load_state_dict(best_trial['state'])
                        
                        # Test evaluation
                        test_metrics = evaluate(model, loaders['test'], loss_fn, DEVICE)
                        
                        print(f"     └─ TEST: acc={test_metrics['acc']:.4f}, "
                              f"macro_f1={test_metrics['macro_f1']:.4f}, "
                              f"weighted_f1={test_metrics['weighted_f1']:.4f}")
                        
                        # Store results
                        result = {
                            'seed': seed,
                            'task': task_name,
                            'encoder': encoder_name,
                            'fusion': fusion_name,
                            'num_classes': num_classes,
                            'best_hp_idx': best_trial['hp_idx'],
                            'lora_rank': hp['lora_rank'],
                            'lora_alpha': hp['lora_alpha'],
                            'lora_dropout': hp['lora_dropout'],
                            'backbone_lr': hp['backbone_lr'],
                            'head_lr': hp['head_lr'],
                            'val_f1': best_trial['val_f1'],
                            'test_acc': test_metrics['acc'],
                            'test_macro_f1': test_metrics['macro_f1'],
                            'test_weighted_f1': test_metrics['weighted_f1'],
                            'test_loss': test_metrics['loss'],
                        }
                        all_results.append(result)
                        
                        # Save intermediate results
                        pd.DataFrame(all_results).to_csv(results_file, index=False)
                        
                        del model
                        cleanup()
                    else:
                        print(f"     └─ No valid trial completed")
                
                # Cleanup after encoder
                del loaders, train_ds, loss_fn
                cleanup_aggressive()
    
    return all_results, results_file


